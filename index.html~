---
layout: default
title: Home
---

<div class="posts">
  {% for post in paginator.posts %}
  <div class="post">
    <h1 class="post-title">
      <a href="{{ post.url }}">
        <em>{{ post.category }}</em> {{ post.title }}
      </a>
      <span class="post-date">{{ post.date}}</span>
    </h1>
<!--     {{ post.excerpt }} -->
  </div>
  {% endfor %}
</div>

<div class="pagination">
  {% if paginator.next_page %}
    <a class="pagination-item older" href="{{ site.baseurl }}page{{paginator.next_page}}">{{ site.data.lang.cn.page_prev }}</a>
  {% else %}
    <span class="pagination-item older">{{ site.data.lang.cn.page_prev }}</span>
  {% endif %}
  {% if paginator.previous_page %}
    {% if paginator.page == 2 %}
      <a class="pagination-item newer" href="{{ site.baseurl }}">{{ site.data.lang.cn.page_next }}</a>
    {% else %}
      <a class="pagination-item newer" href="{{ site.baseurl }}page{{paginator.previous_page}}">{{ site.data.lang.cn.page_next }}</a>
    {% endif %}
  {% else %}
    <span class="pagination-item newer">{{ site.data.lang.cn.page_next }}</span>
  {% endif %}
</div>
<script src="public/jquery.js"></script>
<script>
;(function($){
var _c={length:0},_pre = 'cate_style_';
$('.posts .post-title').each(function(){
	var $em = $(this).find('em').eq(0),
	emv = $em.text();
	if(!_c[emv]) {
		_c[emv] = _pre+_c.length;
		_c.length++;
	}
	$em.addClass(_c[emv]);
})
}(jQuery));
</script>



